<mujoco model="two_link_inverted_pendulum_car">
<!-- 编译器选项  -->
  <compiler 
      coordinate="local" 
      angle="radian" 
      autolimits="true"/>

<!--配置dt-->
  <option 
      timestep="0.002" 
      integrator="RK4" 
      cone="elliptic"/>

 <!--防止穿模,给出摩擦系数-->
  <!-- <contact>
    <pair geom1="pole1" geom2="pole2" friction="0.8 0.01 0.05"/>
    <pair geom1="chassis" geom2="pole1" friction="0.8 0.01 0.05"/>
  </contact>  -->
<!--上面的部分暂时注释掉,防止额外计算,我们可以通过RL env中限制poles的角度为终止条件,穿模可忽略-->

<!--模板配置-->
  <default>
    <joint damping="0.02" armature="0.001"/>
    <geom condim="3" friction="0.8 0.01 0.005" solref="0.01 1" solimp="0.9 0.95 0.001"/>
  </default>

<!--美观的地板😃-->
  <asset>
    <texture name="grid" type="2d" builtin="checker" rgb1=".1 .2 .3"
     rgb2=".2 .3 .4" width="300" height="300"/>
    <material name="grid" texture="grid" texrepeat="8 8" reflectance=".2"/>
  </asset>


  <worldbody>
    <geom name="ground" size="3 3 .1" type="plane" material="grid" friction="1.2 0.01 0.005"/>

    <light pos="0 0 3"/>

 <!--重量的分配:底盘0.145kg+车身0.755kg+杆子0.1kg ;两轮子0.1kg总计1.1,有待商榷-->
    <body name="chassis" pos="0 0 0.0335">
        <freejoint name="chassis"/>
        <geom name="chassis" type="cylinder" size="0.02 0.08" rgba="0.2 0.6 0.8 1" zaxis="0 1 0" mass="0.001"/> <!--0.145-->

        <geom name="pole1" type="box" pos="0 0 0.073" size=".0335 0.06 0.053" rgba="0 1 0 1" mass="0.9"/>

        <body name="left_wheel" pos="0 0.08 0">
            <joint name="left_wheel" type="hinge" damping="0.05" armature="0.01" axis="0 1 0"/>
            <geom name="left_wheel" type="cylinder" size="0.0335 0.01" rgba="0 0 0 1" zaxis="0 1 0" friction="1.6 0.01 0.005" solref="0.02 1.2" 
          solimp="0.8 0.95 0.001 0.5 2" mass="0.05"/>
        </body>

        <body name="right_wheel" pos="0 -0.08 0">
            <joint name="right_wheel" type="hinge" damping="0.05" armature="0.01" axis="0 1 0"/>
            <geom name="right_wheel" type="cylinder" size="0.0335 0.01" rgba="0 0 0 1" zaxis="0 1 0" friction="1.6 0.01 0.005" solref="0.02 1.2" 
          solimp="0.8 0.95 0.001 0.5 2" mass="0.05"/>
        </body>
        
        
        <body name="pole2" pos="0 0 0.126">
            <joint name="pole2" type="hinge" axis="0 1 0"/>
            <geom name="pole2" type="cylinder" pos="0 0 0.195" size="0.005 0.195" friction="0.2 0.01 0.005" rgba="1 0 0 1" zaxis="0 0 1" mass="0.1"/>
        </body>
        


        <site name="imu_site" pos="0 0 0.04"/>
    </body>
  </worldbody>

<!--电机,提供力矩,左右轮,电机型号官网找的,Gemini推荐的ctrlrange和gear参数,以及joint中损耗相关-->
  <actuator>
    <motor name="left_motor"  joint="left_wheel"  gear="2.4" ctrlrange="-30 30"/>
    <motor name="right_motor" joint="right_wheel" gear="2.4" ctrlrange="-30 30"/>
  </actuator>
<!-- <actuator>
  <velocity name="left_motor" joint="left_wheel" kv="3.5" gear="1"/>
  <velocity name="right_motor" joint="right_wheel" kv="3.5" gear="1"/>
</actuator> -->



<!--模拟传感器,8个变量-->  
  <sensor>
    <!--qpos:-->
    <jointpos name="theta_left" joint="left_wheel"/>
    <jointpos name="theta_right" joint="right_wheel"/>
    <!--关于绝对空间的theta!而非相对pole1的!-->
    <framequat name="theta_pole1" objtype="site" objname="imu_site"/> 
    <framequat name="theta_pole2" objtype="body" objname="pole2"/>

    <!--qvel:-->
    <jointvel name="theta_left_dot" joint="left_wheel"/>
    <jointvel name="theta_right_dot" joint="right_wheel"/>
    <frameangvel name="theta_pole1_dot" objtype="site" objname="imu_site"/>
    <frameangvel name="theta_pole2_dot" objtype="body" objname="pole2"/>
    
  </sensor>
</mujoco>